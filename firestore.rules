rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incomingData() {
      return request.resource.data;
    }

    function existingData() {
      return resource.data;
    }

    // Reservation validation
    function isValidReservation(data) {
      return data.keys().hasAll(['roomId', 'roomName', 'startTime', 'endTime', 'title', 'userName', 'userId', 'createdAt', 'updatedAt'])
        && data.roomId is string && data.roomId.size() <= 50
        && data.roomName is string && data.roomName.size() <= 100
        && data.startTime is string && data.startTime.size() <= 50
        && data.endTime is string && data.endTime.size() <= 50
        && data.title is string && data.title.size() <= 200
        && data.userName is string && data.userName.size() <= 100
        && data.userId == request.auth.uid;
    }

    match /reservations/{reservationId} {
      allow read: if true; // El calendario es visible para todos
      
      allow create: if isSignedIn() 
        && isEmailVerified() 
        && isValidReservation(incomingData())
        && incomingData().createdAt == incomingData().updatedAt;

      allow update: if isOwner(existingData().userId)
        && isEmailVerified()
        && isValidReservation(incomingData())
        && incomingData().userId == existingData().userId
        && incomingData().createdAt == existingData().createdAt;

      allow delete: if isOwner(existingData().userId)
        && isEmailVerified();
    }
  }
}
